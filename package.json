{
  "name": "proctor-browser",
  "version": "1.4.2",
  "description": "AI Proctored Exam Browser",
  "main": "main.js",
  "scripts": {
    "start": "electron . --no-sandbox",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "bundle-python": "node bundle-python.js"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "https-proxy-agent": "^9.0.0"
  },
  "build": {
    "appId": "com.proctor.browser",
    "productName": "Procta Browser",
    "asar": true,
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "proctor.py"
    ],
    "extraResources": [
      {
        "from": "proctor.py",
        "to": "proctor.py"
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "ArihantK15",
      "repo": "proctor-browser"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "category": "public.app-category.education",
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "createDesktopShortcut": true,
      "runAfterFinish": true
    }
  }
}
