app.procta.net {
    encode gzip

    # ── Global security headers ──────────────────────────────────────
    header {
        # HSTS: force HTTPS for 1 year
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        # Prevent clickjacking
        X-Frame-Options "DENY"
        # Block MIME sniffing
        X-Content-Type-Options "nosniff"
        # Referrer policy: only send origin on cross-origin requests
        Referrer-Policy "strict-origin-when-cross-origin"
        # Prevent other sites from embedding our resources
        X-Permitted-Cross-Domain-Policies "none"
        # Isolate this origin from others (mitigates Spectre-style attacks)
        Cross-Origin-Opener-Policy "same-origin"
    }

    # ── Static CSS / JS / SVG / favicon ────────────────────────────────
    # Serve pre-compressed .gz variants when available (dashboard.html
    # is ~150KB uncompressed, ~35KB gzipped). Caddy falls back to
    # on-the-fly gzip for other assets.
    @assets path *.css *.js *.svg *.ico *.html
    handle @assets {
        root * /srv
        file_server {
            precompress gzip
        }
        header Cache-Control "no-cache, must-revalidate"
    }
    # ── Other static (images, fonts, downloads) — fine to cache hard ──
    handle /static/* {
        root * /srv
        file_server
        header Cache-Control "public, max-age=86400"
    }

    # ── HTML pages: no-cache so auth checks always run fresh ──
    handle /dashboard {
        root * /srv/static
        rewrite * /dashboard.html
        file_server
        header Cache-Control "no-cache, no-store, must-revalidate"
    }
    handle /download {
        root * /srv/static
        rewrite * /download.html
        file_server
        header Cache-Control "no-cache, no-store, must-revalidate"
    }
    handle /register {
        root * /srv/static
        rewrite * /register.html
        file_server
        header Cache-Control "no-cache, no-store, must-revalidate"
    }
    handle /student {
        root * /srv/static
        rewrite * /student.html
        file_server
        header Cache-Control "no-cache, no-store, must-revalidate"
    }

    # ── Everything else: API ──
    handle {
        reverse_proxy api:8000 {
            flush_interval -1
        }
    }
}
