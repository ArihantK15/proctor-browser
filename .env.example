SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

ADMIN_PASSWORD=your-admin-password
EXIT_CODE=EXIT2026
EXAM_ACCESS_CODE=

SCREENSHOTS_DIR=/app/screenshots

# GitHub Releases URLs — update version number after each release tag.
# Filename convention (since v2.x):
#   macOS arm64 : Procta-Browser-<ver>-arm64.dmg
#   macOS x64   : Procta-Browser-<ver>.dmg
#   Windows     : Procta-Browser-Setup-<ver>.exe
DOWNLOAD_MAC_ARM=https://github.com/ArihantK15/proctor-browser/releases/download/v2.1.3/Procta-Browser-2.1.3-arm64.dmg
DOWNLOAD_MAC_X64=https://github.com/ArihantK15/proctor-browser/releases/download/v2.1.3/Procta-Browser-2.1.3.dmg
DOWNLOAD_WIN=https://github.com/ArihantK15/proctor-browser/releases/download/v2.1.3/Procta-Browser-Setup-2.1.3.exe
