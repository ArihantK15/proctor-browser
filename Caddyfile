app.procta.net {
    # ── Static CSS / JS / SVG / favicon ────────────────────────────────
    # `no-cache` here means "browser may cache but MUST revalidate via
    # ETag on every request." So a deploy with new CSS lights up
    # immediately for users (they get a 304 when unchanged, fresh bytes
    # when the file moved). The previous max-age=86400 baked stale CSS
    # into browsers for 24h after every deploy — visual updates were
    # invisible until the next morning.
    @assets path *.css *.js *.svg *.ico *.html
    handle @assets {
        root * /srv
        file_server
        header Cache-Control "no-cache, must-revalidate"
    }
    # ── Other static (images, fonts, downloads) — fine to cache hard ──
    handle /static/* {
        root * /srv
        file_server
        header Cache-Control "public, max-age=86400"
    }

    # ── HTML pages: no-cache so auth checks always run fresh ──
    handle /dashboard {
        root * /srv/static
        rewrite * /dashboard.html
        file_server
        header Cache-Control "no-cache, no-store, must-revalidate"
    }
    handle /download {
        root * /srv/static
        rewrite * /download.html
        file_server
        header Cache-Control "no-cache, no-store, must-revalidate"
    }
    handle /register {
        root * /srv/static
        rewrite * /register.html
        file_server
        header Cache-Control "no-cache, no-store, must-revalidate"
    }
    handle /student {
        root * /srv/static
        rewrite * /student.html
        file_server
        header Cache-Control "no-cache, no-store, must-revalidate"
    }

    # ── Everything else: API ──
    handle {
        reverse_proxy api:8000 {
            flush_interval -1
        }
    }
}
