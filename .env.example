SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

ADMIN_PASSWORD=your-admin-password
EXIT_CODE=EXIT2026
EXAM_ACCESS_CODE=

# ── Storage ──────────────────────────────────────────────────────
SCREENSHOTS_DIR=/app/screenshots
SCREENSHOT_RETENTION_DAYS=90          # auto-cleanup old screenshots

# ── CORS ──────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Defaults to Electron file://
# origin, localhost (dev), and https://app.procta.net.
# Set this explicitly in production to restrict access.
# CORS_ALLOWED_ORIGINS=https://app.procta.net

# ── Redis (for SSE pub/sub, rate limiting, invite dedup) ─────────
REDIS_URL=redis://redis:6379

# ── Installer downloads ──────────────────────────────────────────
# (see RELEASE_REPO below). Normally you don't need to set DOWNLOAD_*
# — leave them blank and the backend resolves them on the fly, cached
# for 10 minutes.
#
# Only set these if you want to PIN a specific version (e.g. during a
# staged rollout, or if the latest release is broken). Env values
# OVERRIDE auto-discovery.
DOWNLOAD_MAC_ARM=
DOWNLOAD_MAC_X64=
DOWNLOAD_WIN=

# Auto-discovery config (these have sensible defaults, shown here for
# reference — uncomment only to override)
# RELEASE_REPO=ArihantK15/proctor-browser
# RELEASE_TTL_SEC=600
# GITHUB_TOKEN=   # optional — raises API limit from 60/hr to 5000/hr

# ── LLM (provider-agnostic) ──────────────────────────────────────
# Powers AI question generation, auto-tags, and scorecard insights.
# If unset, those features return 503 with a clear error — everything
# else still works (proctoring, exam delivery, scoring, dashboards).
#
# Works with any OpenAI-compatible chat-completions API. Pick whichever
# free provider you prefer:
#
#   GROQ (recommended — fastest, generous free tier, no credit card)
#     LLM_API_KEY=gsk_xxxxxxxxxxxxxxxx
#     LLM_BASE_URL=https://api.groq.com/openai/v1
#     LLM_MODEL=llama-3.3-70b-versatile
#     Sign up: https://console.groq.com/keys
#     Limit:   14,400 req/day @ ~600 tok/s
#
#   OPENROUTER (huge model selection, some truly :free models)
#     LLM_API_KEY=sk-or-v1-xxxxxxxx
#     LLM_BASE_URL=https://openrouter.ai/api/v1
#     LLM_MODEL=google/gemini-2.0-flash-exp:free
#     Sign up: https://openrouter.ai/keys
#     Limit:   varies per model; :free models are rate-limited
#
#   CEREBRAS (fastest Llama, ~10K req/day free)
#     LLM_API_KEY=csk-xxxxxxxx
#     LLM_BASE_URL=https://api.cerebras.ai/v1
#     LLM_MODEL=llama3.3-70b
#     Sign up: https://cloud.cerebras.ai
#
#   LOCAL OLLAMA (no API call, but slow on CPU and needs a host with
#   16+ GB RAM for 70B models; consider llama3.1:8b for the droplet)
#     LLM_API_KEY=ollama-no-key-needed
#     LLM_BASE_URL=http://localhost:11434/v1
#     LLM_MODEL=llama3.1:8b
LLM_API_KEY=
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile
# LLM_TIMEOUT=30                        # seconds, optional

# ── Monitoring (optional) ────────────────────────────────────────
# Sentry error tracking — set to enable automatic 500 reporting.
# Get your DSN at https://sentry.io/organizations/<org>/projects/
# SENTRY_DSN=https://xxx@yyy.ingest.sentry.io/zzz
# SENTRY_ENVIRONMENT=production          # default: production
# SENTRY_TRACES_SAMPLE_RATE=0.1          # default: 0.1 (10%)
# SENTRY_PROFILES_SAMPLE_RATE=0.0        # default: 0 (disabled)

# Legacy GROQ_* names still work as fallbacks if you've already set them.
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile
