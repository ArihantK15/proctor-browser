app.procta.net {
    # ── Static files: served directly by Caddy, never hits FastAPI ──
    handle /static/* {
        root * /srv
        file_server
        header Cache-Control "public, max-age=86400"
    }

    # ── HTML pages: no-cache so auth checks always run fresh ──
    handle /dashboard {
        root * /srv/static
        rewrite * /dashboard.html
        file_server
        header Cache-Control "no-cache, no-store, must-revalidate"
    }
    handle /download {
        root * /srv/static
        rewrite * /download.html
        file_server
        header Cache-Control "no-cache, no-store, must-revalidate"
    }
    handle /register {
        root * /srv/static
        rewrite * /register.html
        file_server
        header Cache-Control "no-cache, no-store, must-revalidate"
    }
    handle /student {
        root * /srv/static
        rewrite * /student.html
        file_server
        header Cache-Control "no-cache, no-store, must-revalidate"
    }

    # ── Everything else: API ──
    handle {
        reverse_proxy api:8000 {
            flush_interval -1
        }
    }
}
